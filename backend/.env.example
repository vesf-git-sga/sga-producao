# Porta em que o servidor backend irá rodar
PORT=5000

# String de conexão com o banco de dados PostgreSQL
# Formato: postgres://usuario:senha@host:porta/nome_do_banco
DATABASE_URL=postgres://postgres:senha_exemplo@localhost:5432/sga_db

# Chave secreta usada para assinar os tokens JWT (Use uma string longa, forte e aleatória)
JWT_SECRET=sua_chave_secreta_aqui_exemplo
